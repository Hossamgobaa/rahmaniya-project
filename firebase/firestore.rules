/* =====================================================================
   firestore.rules — أقصى مستوى أمان لمشروع "دليل الرحمانية"
   ---------------------------------------------------------------------
   طريقة التفعيل:
   1) Firebase Console → مشروعك → Firestore Database → تبويب Rules
   2) امسح المحتوى الموجود واستبدله بالكود ده بالكامل
   3) دوس "Publish"

   الفكرة (Read Only للزوار، Write فقط للأدمن المسجّل دخول):
   - أي زائر (بدون أي تسجيل دخول) يقدر "يقرأ" البيانات فقط ليتصفح الموقع.
   - أي كتابة (إضافة/تعديل/حذف) بأي شكل، في أي Collection، ممنوعة تمامًا
     إلا لمستخدم مسجّل دخول فعليًا (request.auth != null) — يعني حساب
     الأدمن الوحيد اللي أنشأته من Authentication → Users.
   - مفيش أي استثناءات أو "ثغرات" مفتوحة لأي عملية كتابة من الواجهة العامة،
     ولا حتى لحاجات بسيطة زي عدادات المشاهدات.
   ===================================================================== */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ----------------------------------------------------------------
       (موصى به بشدة) قفل الكتابة على إيميل الأدمن الوحيد بالاسم تحديدًا،
       بدل أي حساب مسجّل دخول بشكل عام. غيّر الإيميل تحت لإيميلك الحقيقي
       (نفس الإيميل اللي أنشأته في Authentication → Users):
       ---------------------------------------------------------------- */
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == "hossamgobaa123344@gmail.com";
    }

    match /{collection}/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

/* =====================================================================
   ملاحظة: لو سيبت الإيميل في isAdmin() كما هو (ضع_إيميل_الأدمن_هنا...)،
   فلن يستطيع حتى حسابك الإداري الكتابة لحد ما تحط إيميلك الحقيقي بدله.
   كحل بديل أسهل (أقل تشددًا بدرجة واحدة فقط، لكنه يكفي عمليًا لأن أنت
   الوحيد الذي سينشئ حسابًا في Authentication):
   استبدل isAdmin() بالسطر التالي:

     function isAdmin() { return request.auth != null; }

   ===================================================================== */
